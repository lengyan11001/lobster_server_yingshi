{
  "image.generate": {
    "description": "生成图片（文生图/图生图）。速推统一 generate 入口，返回 task_id 后用 task.get_result 取结果。",
    "upstream": "sutui",
    "upstream_tool": "generate",
    "enabled": true,
    "is_default": true,
    "arg_schema": {
      "type": "object",
      "properties": {
        "prompt": { "type": "string", "description": "生成提示词" },
        "model": { "type": "string", "description": "可选（省略时默认 fal-ai/flux-2/flash）" },
        "image_url": { "type": "string", "description": "图生图时传入图片 URL" },
        "image_size": { "type": "string", "description": "可选，如 square_hd, landscape_16_9" }
      },
      "required": ["prompt"]
    }
  },
  "video.generate": {
    "description": "生成视频（文生视频或图生视频）。速推统一 generate 入口，返回 task_id 后用 task.get_result 轮询（通常 30–120 秒），服务端会自动长轮询。",
    "upstream": "sutui",
    "upstream_tool": "generate",
    "enabled": true,
    "is_default": true,
    "arg_schema": {
      "type": "object",
      "properties": {
        "model": { "type": "string", "description": "可选（省略时默认 sora2 即 fal-ai/sora-2/text-to-video）" },
        "prompt": { "type": "string", "description": "描述/动作提示词" },
        "image_url": { "type": "string", "description": "图生视频时必传，公开可访问的图片 URL；本地图可用 sutui.transfer_url 先转存" },
        "aspect_ratio": { "type": "string", "description": "可选，宽高比 16:9 或 9:16" },
        "duration": { "type": "integer", "description": "可选，视频时长秒数，如 5 或 10" }
      },
      "required": ["model", "prompt"]
    }
  },
  "task.get_result": {
    "description": "查询任务结果（统一能力入口）。若任务仍在处理中（如视频生成），服务端会每 60 秒自动轮询一次，最多等待 30 分钟，无需重复调用。",
    "upstream": "sutui",
    "upstream_tool": "get_result",
    "enabled": true,
    "is_default": true,
    "arg_schema": {
      "type": "object",
      "properties": {
        "task_id": { "type": "string", "description": "任务 ID" }
      },
      "required": ["task_id"]
    }
  },
  "image.understand": {
    "description": "理解/分析图片内容（i2t）。通过多模态 LLM（Gemini / Claude 等）描述、识别、解读图片。返回文本而非图片。",
    "upstream": "sutui",
    "upstream_tool": "generate",
    "enabled": true,
    "is_default": true,
    "arg_schema": {
      "type": "object",
      "properties": {
        "prompt": { "type": "string", "description": "提问/指令，如「详细描述这张图片」「图中有什么文字」" },
        "image_url": { "type": "string", "description": "单张图片 URL（会自动转为 image_urls 数组）" },
        "image_urls": { "type": "array", "description": "图片 URL 数组（最多 10 张）" },
        "model": { "type": "string", "description": "底层 LLM，默认 google/gemini-3-pro-preview" }
      },
      "required": ["prompt"]
    }
  },
  "video.understand": {
    "description": "理解/分析视频内容（v2t）。通过多模态 LLM（Gemini / Claude 等）描述、总结、解读视频。返回文本而非视频。",
    "upstream": "sutui",
    "upstream_tool": "generate",
    "enabled": true,
    "is_default": true,
    "arg_schema": {
      "type": "object",
      "properties": {
        "prompt": { "type": "string", "description": "提问/指令，如「这个视频讲了什么」「总结视频内容」" },
        "video_url": { "type": "string", "description": "单个视频 URL（会自动转为 video_urls 数组）" },
        "video_urls": { "type": "array", "description": "视频 URL 数组（最多 5 个，支持 mp4/mov/webm）" },
        "model": { "type": "string", "description": "底层 LLM，默认 google/gemini-3-pro-preview" }
      },
      "required": ["prompt"]
    }
  },
  "sutui.search_models": {
    "description": "搜索速推可用模型与参数 Schema",
    "upstream": "sutui",
    "upstream_tool": "search_models",
    "enabled": true,
    "is_default": false,
    "arg_schema": {
      "type": "object",
      "properties": {
        "query": { "type": "string", "description": "自由文本搜索" },
        "category": { "type": "string", "enum": ["image", "video", "audio", "all"] },
        "capability": { "type": "string", "enum": ["t2i", "i2i", "t2v", "i2v", "v2v", "t2a", "stt", "i2t", "v2t"] },
        "model_id": { "type": "string" }
      }
    }
  },
  "sutui.guide": {
    "description": "获取速推模型教程与最佳实践",
    "upstream": "sutui",
    "upstream_tool": "guide",
    "enabled": true,
    "is_default": false,
    "arg_schema": {
      "type": "object",
      "properties": {
        "query": { "type": "string" },
        "skill_id": { "type": "string" },
        "category": { "type": "string", "enum": ["image", "video", "audio", "tool"] }
      }
    }
  },
  "sutui.account": {
    "description": "速推账户管理（余额/签到/套餐/支付）",
    "upstream": "sutui",
    "upstream_tool": "account",
    "enabled": true,
    "is_default": false,
    "arg_schema": {
      "type": "object",
      "properties": {
        "action": { "type": "string", "enum": ["balance", "checkin", "packages", "pay"], "default": "balance" },
        "package_id": { "type": "integer" }
      }
    }
  },
  "sutui.parse_video": {
    "description": "解析视频分享链接并获取下载地址",
    "upstream": "sutui",
    "upstream_tool": "parse_video",
    "enabled": true,
    "is_default": false,
    "arg_schema": {
      "type": "object",
      "properties": { "url": { "type": "string" } },
      "required": ["url"]
    }
  },
  "sutui.transfer_url": {
    "description": "将公网媒体直链转存到速推 CDN（本机 save-url 拉取 v3-tasks 视频失败时也会自动调用）。速推接口的 type 仅有 image / audio：视频（含 .mp4、v3-tasks 成品链）也请传 type=image，并非误用；返回 URL 常见路径为 /mcp-images/、后缀可能为 .jpg，以实际文件内容与 Content-Type 为准。音频必须用 type=audio。",
    "upstream": "sutui",
    "upstream_tool": "transfer_url",
    "enabled": true,
    "is_default": false,
    "arg_schema": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "description": "公网可访问的直链。可为图片，也可为视频（如 cdn-video…/v3-tasks/…/*.mp4）。"
        },
        "type": {
          "type": "string",
          "enum": ["image", "audio"],
          "default": "image",
          "description": "速推仅支持 image 与 audio。转存视频时请填 image；仅音频填 audio。"
        }
      },
      "required": ["url"]
    }
  },
  "comfly.chat": {
    "description": "Comfly 对话补全（OpenAI 兼容）。可用于前端技能调用 Comfly 的 LLM 能力，如商品详情图文案等。",
    "upstream": "comfly",
    "upstream_tool": "chat_completions",
    "enabled": true,
    "is_default": false,
    "arg_schema": {
      "type": "object",
      "properties": {
        "model": { "type": "string", "description": "Comfly 模型名，如 veo3.1-fast" },
        "messages": { "type": "array", "description": "OpenAI 格式的 messages 数组" },
        "temperature": { "type": "number", "description": "采样温度，默认 0.7" },
        "max_tokens": { "type": "integer", "description": "最大生成 token 数" }
      },
      "required": ["model", "messages"]
    }
  },
  "sutui.speak": {
    "description": "语音合成和音色管理",
    "upstream": "sutui",
    "upstream_tool": "speak",
    "enabled": true,
    "is_default": false,
    "arg_schema": {
      "type": "object",
      "properties": {
        "action": { "type": "string", "enum": ["synthesize", "list_voices", "design_voice", "clone_voice"], "default": "synthesize" },
        "text": { "type": "string" },
        "voice_id": { "type": "string" },
        "prompt": { "type": "string" },
        "audio_url": { "type": "string" },
        "file_id": { "type": "integer" },
        "voice_name": { "type": "string" },
        "model": { "type": "string", "enum": ["speech-2.8-hd", "speech-2.8-turbo", "speech-2.6-hd", "speech-2.6-turbo"], "default": "speech-2.8-hd" },
        "speed": { "type": "number", "default": 1 }
      }
    }
  }
}
