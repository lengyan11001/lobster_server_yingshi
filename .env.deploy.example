# 复制为 .env.deploy（勿提交）。用于 scripts/deploy_from_local.sh / deploy_server.sh
#
# 大陆机（主）：注册登录、积分、支付、鉴权、技能商店等 → LOBSTER_DEPLOY_HOST
# 海外机（可选）：Messenger / Twilio 等 Meta 与第三方 Webhook 打得到的那台 → LOBSTER_DEPLOY_HOST_OVERSEAS
#   域名 lobster-server.icu 当前解析到海外公网 IP，需与线上一致部署同仓库 main。

LOBSTER_DEPLOY_HOST=ubuntu@42.194.209.150
LOBSTER_DEPLOY_SSH_KEY=/path/to/your_private_key
# 私钥带口令时必须写入此项：deploy_from_local.sh / scripts/tail_remote_logs.sh / ssh_run_remote.sh
# 会用 SSH_ASKPASS 非交互解锁，避免终端索要口令（勿提交 .env.deploy）
# LOBSTER_SSH_KEY_PASSPHRASE=your_key_passphrase
LOBSTER_DEPLOY_REMOTE_DIR=/root/lobster_server
# 可选：海外（Messenger/Twilio）。与 docs/云服务器部署说明.md 相同：SSH 密钥 + 远端 git pull（默认复用 LOBSTER_DEPLOY_SSH_KEY，海外用户须已授权该公钥）：
# LOBSTER_DEPLOY_HOST_OVERSEAS=ubuntu@43.162.111.36
# LOBSTER_DEPLOY_REMOTE_DIR_OVERSEAS=/opt/lobster-server
# LOBSTER_DEPLOY_SSH_KEY_OVERSEAS=/path/to/overseas_only_key

# ── 密码备用登录（SSH 密钥失败时由 ssh_run_remote_pw.py 使用，需 pip install paramiko）──
# LOBSTER_DEPLOY_PASSWORD=server_password_here
# LOBSTER_DEPLOY_PASSWORD_OVERSEAS=overseas_password_here
