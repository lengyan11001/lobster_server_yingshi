# 复制为 .env.deploy 并填写（勿提交 .env.deploy）
# 用于 scripts/deploy_from_local.sh 与 deploy_full_from_local.sh

LOBSTER_DEPLOY_HOST=root@47.120.39.220
LOBSTER_DEPLOY_SSH_KEY=/path/to/your/key
LOBSTER_DEPLOY_REMOTE_DIR=/root/lobster_server

# 仅「完整部署」deploy_full_from_local.sh 需要：服务器上 lobster_online 根目录（其下应有 static/）
LOBSTER_ONLINE_REMOTE_DIR=/root/lobster_online

# 若 online 不在 lobster-server 同级目录，可指定本地路径
# LOBSTER_ONLINE_LOCAL_DIR=/path/to/lobster_online
