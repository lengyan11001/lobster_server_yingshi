# ============================================
# Lobster Config (复制为 .env 后按需填写，勿将含真实 key 的 .env 打包分发)
# 服务器上一键配置：在 lobster_server 仓库中运行 python3 scripts/config_env.py（交互或 CONFIG_* 环境变量）
# ============================================

SECRET_KEY=lobster-secret-change-me
DEBUG=true

# 仅测试/脚本用；在线版不创建默认用户
# DEFAULT_USER_EMAIL=user@lobster.local
# DEFAULT_USER_PASSWORD=lobster123

HOST=0.0.0.0
PORT=8000
MCP_PORT=8001
# MCP 是否在 invoke_capability 成功后自动 POST /api/assets/save-url。在线版素材以用户本机为准：默认关闭；仅本机 backend+MCP 一体且需 MCP 写库时设 MCP_AUTOSAVE_ASSETS=1
# MCP_AUTOSAVE_ASSETS=0
# 公网根（定死 ECS）：upload-temp 外链、回调、速推拉图。仅当前面有 Nginx+HTTPS 时改为 https://你的域名
PUBLIC_BASE_URL=http://42.194.209.150

# Messenger（仅海外实例通常需要）：与大陆登录共用 SECRET_KEY，但海外 SQLite 无 users 行时仍允许 /api/messenger/configs* 使用 JWT sub
# MESSENGER_TRUST_JWT_WITHOUT_USER=false

# 对话模型 API Key（选填；不填则仅用 OpenClaw/速推）
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=

OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_AGENT_ID=main
# 是否在启动时尝试本机拉起 OpenClaw（需 node + openclaw.mjs，与 lobster_online 完整包一致）。
# 纯 API 的 Linux 服务器通常没有这些文件：可不配，启动时仅打 INFO 并跳过；若仍想关闭探测可设 false。
# OPENCLAW_AUTOSTART=false

CAPABILITY_SUTUI_MCP_URL=
# 服务器侧速推 Token：能力由服务器转发、扣用户积分时使用（必填，否则能力调用报错）
# 可选：sutui-chat 转发 xskill 前重写 model（JSON 对象）。键=客户端传入的 model，值=速推分销商侧有通道的真实 id。
# 例：网页智能对话里能用的 id 与 OpenClaw 用的 deepseek/deepseek-chat 不一致时配置。
# SUTUI_CHAT_MODEL_MAP_JSON={"deepseek/deepseek-chat":"你在下拉或 F12 里看到的 model id"}
# sutui-chat：主模型失败/非标准 OpenAI choices 时按顺序换备用模型（JSON 数组，用速推 model id，自动剥离 anthropic/ 等前缀）。默认 deepseek-chat → claude-opus-4-6；Token 池 402/401 等不会无意义重试。
# SUTUI_CHAT_MODEL_FALLBACK_CHAIN_JSON=["deepseek-chat","gpt-4o"]
# sutui-chat：速推 docs 无定价时，事后按 usage 折算扣费（每 1000 token 扣多少积分，ceil）。默认 1.0；设 0 则无极低价近似时可能算成 0 积分。上游若省略 usage（非流式常见），已用 messages/max_tokens 粗估再折算。
# SUTUI_CHAT_FALLBACK_CREDITS_PER_1K=1.0
# 网页 /api/sutui-llm/models 的 recommended 与探测快照默认推荐；不填时只要在目录里存在 deepseek-chat（或 deepseek/deepseek-chat）即优先于其它模型
# SUTUI_LLM_RECOMMENDED_ID=
# 国内实例：每小时速推 LLM 目录 + chat 可用性探测（写 data/sutui_llm_snapshot.json）。设为 0/false/off 可关闭，不影响对话转发与速推对账。
# LOBSTER_SUTUI_LLM_PROBE_ENABLED=0

# SUTUI_SERVER_TOKEN=
# 多个速推算力 Token（逗号分隔）时做负载均衡；不填则用 SUTUI_SERVER_TOKEN
# SUTUI_SERVER_TOKENS=sk-xxx,sk-yyy,sk-zzz
#
# 品牌分流：终端用户 JWT 须为 brand_mark=bihuo|yingshi，对应池取 Token；无品牌不允许走速推（无 USER 兜底）
# SUTUI_SERVER_TOKEN_BIHUO=
# SUTUI_SERVER_TOKENS_BIHUO=sk-...,sk-...
# SUTUI_SERVER_TOKEN_YINGSHI=
# SUTUI_SERVER_TOKENS_YINGSHI=sk-...,sk-...
# 已弃用：SUTUI_SERVER_TOKEN_USER / SUTUI_SERVER_TOKENS_USER 不再参与用户侧选 Token
#
# MCP 需能解析 JWT 中的 brand_mark：与 Backend 使用同一 SECRET_KEY（或设 LOBSTER_SECRET_KEY）

# 速推对账（国内主实例默认开启；海外设 LOBSTER_SERVER_REGION=overseas 时关闭；与 LLM 探测独立）
# LOBSTER_SUTUI_RECONCILE_ENABLED=true
# LOBSTER_SUTUI_RECONCILE_INTERVAL_SEC=3600

# 在线版速推登录
# SUTUI_OAUTH_LOGIN_URL=

# 本构建仅在线版（online）
LOBSTER_EDITION=online
# 已废弃：前端由 lobster_online 提供，server 仅 API，不再提供 / 与 /static
# SERVE_FRONTEND=
# 独立认证与充值（注册/登录/积分/技能解锁）
LOBSTER_INDEPENDENT_AUTH=true
# 技能商店「调试」包（如微信 OpenClaw、YouTube）额外管理员：逗号分隔登录账号（与 User.email 一致）
# LOBSTER_SKILL_STORE_ADMIN_ACCOUNTS=ops1,ops2
# 完成充值/技能解锁订单时请求头 X-Admin-Secret（仅服务端知晓）
# LOBSTER_RECHARGE_ADMIN_SECRET=

# 自建微信登录（不用速推）：开放平台网站应用
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=

# 付呗聚合支付（替代自建微信支付）：支持微信/支付宝/云闪付扫码
# 文档：https://www.yuque.com/51fubei/openapi
# 参数获取：https://www.yuque.com/51fubei/openapi/ioxtei
# FUBEI_APP_ID=20210617105715486536
# FUBEI_APP_SECRET=d4c9a879e14155f593d9cf9452da7c1e
# FUBEI_STORE_ID=1276011
# 正式环境网关（默认值，通常无需修改）；测试环境改为 https://shq-api-test.51fubei.com/gateway/agent
# FUBEI_GATEWAY_URL=https://shq-api.51fubei.com/gateway/agent
