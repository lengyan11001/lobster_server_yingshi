    },
    "wecom_reply": {
      "name": "企业微信自动回复",
      "description": "接收企业微信消息，由 AI 自动生成回复。需 1000 积分解锁后进入配置页并使用。",
      "type": "builtin",
      "store_visibility": "debug",
      "unlock_price_credits": 1000,
      "status": "available",
      "capabilities": {},
      "tags": ["wecom", "chat", "reply"]
    },
    "messenger_reply": {
      "name": "Facebook Messenger 客服",
      "description": "多应用 Webhook、Meta 消息自动回复；配置与回调走海外 lobster_server（在线版「Messenger」API 基址）。",
      "type": "builtin",
      "store_visibility": "debug",
      "default_installed": true,
      "status": "available",
      "capabilities": {},
      "tags": ["messenger", "meta", "chat", "reply"]
    },
    "comfly_veo_skill": {
      "name": "Comfly Veo 带货视频",
      "description": "本机经 Comfly 调用 Google Veo 图生视频：上传商品图、生成英文 prompt、提交与轮询任务。仅技能商店管理员可见；无需积分解锁。安装后在本机配置 Comfly API Key（或 .env COMFLY_API_KEY / 用户设置）。",
      "type": "builtin",
      "store_visibility": "debug",
      "status": "available",
      "package_config": {
        "comfly_api_base": "https://ai.comfly.chat",
        "video_model": "veo3.1-fast",
        "analysis_model": "gemini-2.5-pro",
        "aspect_ratio": "9:16",
        "enhance_prompt": true,
        "storyboard_image_model": "nano-banana-2"
      },
      "capabilities": {
        "comfly.veo": {
          "description": "Comfly + Veo 图生视频（invoke_capability capability_id=comfly.veo，payload.action=upload|generate_prompts|submit_video|poll_video）",
          "upstream": "local",
          "upstream_tool": "invoke",
          "enabled": true,
          "is_default": false,
          "unit_credits": 0,
          "arg_schema": {
            "type": "object",
            "properties": {
              "action": {
                "type": "string",
                "enum": ["upload", "generate_prompts", "submit_video", "poll_video"],
                "description": "upload: 本机 asset_id 上传得 image_url；generate_prompts: 从 image_url 生成 5 条英文视频 prompt；submit_video: 提交 Veo 任务；poll_video: 查询 task_id 状态与 output"
              },
              "asset_id": { "type": "string", "description": "upload 时必填" },
              "image_url": { "type": "string", "description": "generate_prompts/submit_video 时可用" },
              "prompt": { "type": "string", "description": "submit_video 视频提示词" },
              "task_id": { "type": "string", "description": "poll_video 必填" },
              "video_model": { "type": "string", "description": "覆盖卡片默认 Veo 模型" },
              "analysis_model": { "type": "string", "description": "覆盖卡片默认分析模型" },
              "aspect_ratio": { "type": "string", "description": "如 9:16、16:9" },
              "enhance_prompt": { "type": "boolean", "description": "非英文 prompt 时是否增强" }
            },
            "required": ["action"]
          }
        }
      },
      "tags": ["video", "comfly", "veo", "i2v"]
    },
    "media_edit_skill": {
      "name": "素材剪辑",
      "description": "对素材库视频/图片做叠字、裁剪、画幅、静音、配乐、静图转视频、抽帧；需本机已安装 ffmpeg。1000 积分解锁后可在对话中用自然语言描述剪辑意图（须给出可解析参数）。",
      "type": "builtin",
      "store_visibility": "debug",
      "unlock_price_credits": 1000,
      "status": "available",
      "capabilities": {
        "media.edit": {
          "description": "本地素材剪辑（invoke_capability capability_id=media.edit）",
          "upstream": "local",
          "upstream_tool": "invoke",
          "enabled": true,
          "is_default": false,
          "unit_credits": 0,
          "arg_schema": {
            "type": "object",
            "properties": {
              "operation": {
                "type": "string",
                "enum": ["overlay_text", "trim", "scale_pad", "mute", "mux_audio", "image_to_video", "extract_frame"]
              },
              "asset_id": { "type": "string" },
              "text": { "type": "string" },
              "position": { "type": "string", "enum": ["top", "center", "bottom"] },
              "vertical_align": { "type": "string", "enum": ["top", "center", "bottom"] },
              "horizontal_align": { "type": "string", "enum": ["left", "center", "right"] },
              "margin_x": { "type": "integer" },
              "margin_y": { "type": "integer" },
              "offset_x": { "type": "integer" },
              "offset_y": { "type": "integer" },
              "font_size": { "type": "integer" },
              "font_color": { "type": "string" },
              "font_alpha": { "type": "number" },
              "font_file": { "type": "string" },
              "x_expr": { "type": "string" },
              "y_expr": { "type": "string" },
              "box": { "type": "boolean" },
              "box_color": { "type": "string" },
              "box_alpha": { "type": "number" },
              "box_border_width": { "type": "integer" },
              "border_width": { "type": "integer" },
              "border_color": { "type": "string" },
              "shadow_x": { "type": "integer" },
              "shadow_y": { "type": "integer" },
              "shadow_color": { "type": "string" },
              "shadow_alpha": { "type": "number" },
              "line_spacing": { "type": "integer" },
              "text_align": { "type": "string", "enum": ["left", "center", "right"] },
              "fix_bounds": { "type": "boolean" },
              "start_sec": { "type": "number" },
              "end_sec": { "type": "number" },
              "aspect_ratio": { "type": "string", "enum": ["9:16", "16:9", "1:1", "4:3", "3:4"] },
              "fit_mode": { "type": "string", "enum": ["contain", "cover"] },
              "audio_asset_id": { "type": "string" },
              "duration_sec": { "type": "number" },
              "timestamp_sec": { "type": "number" }
            },
            "required": ["operation", "asset_id"]
          }
        }
      },
      "tags": ["video", "image", "edit", "ffmpeg"]
    },
    "add_more_publish_accounts": {
      "name": "添加更多发布账号",
      "description": "（已开放）可添加多个抖音/小红书/头条等发布账号，无需积分解锁。",
      "type": "builtin",
      "store_visibility": "debug",
      "show_in_store": false,
      "status": "available",
      "capabilities": {},
      "tags": ["publish", "accounts"]
    },
    "sutui_mcp": {
      "name": "速推 MCP",
      "description": "图片生成、视频解析、语音合成、模型搜索等 AI 创作能力",
      "type": "upstream_mcp",
      "store_visibility": "online",
      "default_installed": true,
      "config": {
        "upstream_name": "sutui",
        "upstream_url_env": "CAPABILITY_SUTUI_MCP_URL",
        "upstream_url_default": "https://mcp.sutui.cc/mcp"
      },
      "capabilities": {
        "image.generate": {
          "description": "生成图片（统一能力入口）",
          "upstream": "sutui",
          "upstream_tool": "generate",
          "enabled": true,
          "is_default": true,
          "arg_schema": {
            "type": "object",
            "properties": {
              "prompt": {"type": "string", "description": "生成提示词"},
              "model": {"type": "string", "description": "可选，模型名"},
              "size": {"type": "string", "description": "可选，图像尺寸"}
            },
            "required": ["prompt"]
          }
        },
        "task.get_result": {
          "description": "查询任务结果（统一能力入口）",
          "upstream": "sutui",
          "upstream_tool": "get_result",
          "enabled": true,
          "is_default": true,
          "arg_schema": {
            "type": "object",
            "properties": {
              "task_id": {"type": "string", "description": "任务 ID"}
            },
            "required": ["task_id"]
          }
        },
        "sutui.search_models": {
          "description": "搜索速推可用模型与参数",
          "upstream": "sutui",
          "upstream_tool": "search_models",
          "enabled": true,
          "is_default": false,
          "arg_schema": {
            "type": "object",
            "properties": {
              "query": {"type": "string"},
              "category": {"type": "string", "enum": ["image", "video", "audio", "all"]}
            }
          }
        },
        "sutui.speak": {
          "description": "语音合成和音色管理",
          "upstream": "sutui",
          "upstream_tool": "speak",
          "enabled": true,
          "is_default": false,
          "arg_schema": {
            "type": "object",
            "properties": {
              "action": {"type": "string", "enum": ["synthesize", "list_voices"], "default": "synthesize"},
              "text": {"type": "string"},
              "voice_id": {"type": "string"}
            }
          }
        },
        "sutui.parse_video": {
          "description": "解析视频分享链接并获取下载地址",
          "upstream": "sutui",
          "upstream_tool": "parse_video",
          "enabled": true,
          "is_default": false,
          "arg_schema": {
            "type": "object",
            "properties": {"url": {"type": "string"}},
            "required": ["url"]
          }
        },
        "sutui.guide": {
          "description": "获取速推模型教程与最佳实践",
          "upstream": "sutui",
          "upstream_tool": "guide",
          "enabled": true,
          "is_default": false,
          "arg_schema": {
            "type": "object",
            "properties": {"query": {"type": "string"}}
          }
        },
        "sutui.transfer_url": {
          "description": "转存外部媒体 URL 到 CDN",
          "upstream": "sutui",
          "upstream_tool": "transfer_url",
          "enabled": true,
          "is_default": false,
          "arg_schema": {
            "type": "object",
            "properties": {
              "url": {"type": "string"},
              "type": {"type": "string", "enum": ["image", "audio"], "default": "image"}
            },
            "required": ["url"]
          }
        }
      },
      "tags": ["image", "video", "audio", "ai"]
    }
  }
}
