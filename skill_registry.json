          "upstream_tool": "generate",
          "enabled": true,
          "is_default": true,
          "arg_schema": {
            "type": "object",
            "properties": {
              "prompt": {"type": "string", "description": "生成提示词"},
              "model": {"type": "string", "description": "可选，模型名"},
              "image_url": {"type": "string", "description": "可选，参考图片 URL（图生视频）"},
              "duration": {"type": "integer", "description": "可选，视频时长（秒）"}
            },
            "required": ["prompt"]
          }
        },
        "image.understand": {
          "description": "图片理解/识别",
          "upstream": "sutui",
          "upstream_tool": "generate",
          "enabled": true,
          "is_default": false
        },
        "video.understand": {
          "description": "视频理解/识别",
          "upstream": "sutui",
          "upstream_tool": "generate",
          "enabled": true,
          "is_default": false
        },
        "sutui.account": {
          "description": "查询速推账户信息",
          "upstream": "sutui",
          "upstream_tool": "account",
          "enabled": true,
          "is_default": false
        },
        "task.get_result": {
          "description": "查询任务结果（统一能力入口）",
          "upstream": "sutui",
          "upstream_tool": "get_result",
          "enabled": true,
          "is_default": true,
          "arg_schema": {
            "type": "object",
            "properties": {
              "task_id": {"type": "string", "description": "任务 ID"}
            },
            "required": ["task_id"]
          }
        },
        "sutui.search_models": {
          "description": "搜索速推可用模型与参数",
          "upstream": "sutui",
          "upstream_tool": "search_models",
          "enabled": true,
          "is_default": false,
          "arg_schema": {
            "type": "object",
            "properties": {
              "query": {"type": "string"},
              "category": {"type": "string", "enum": ["image", "video", "audio", "all"]}
            }
          }
        },
        "sutui.speak": {
          "description": "语音合成和音色管理",
          "upstream": "sutui",
          "upstream_tool": "speak",
          "enabled": true,
          "is_default": false,
          "arg_schema": {
            "type": "object",
            "properties": {
              "action": {"type": "string", "enum": ["synthesize", "list_voices"], "default": "synthesize"},
              "text": {"type": "string"},
              "voice_id": {"type": "string"}
            }
          }
        },
        "sutui.parse_video": {
          "description": "解析视频分享链接并获取下载地址",
          "upstream": "sutui",
          "upstream_tool": "parse_video",
          "enabled": true,
          "is_default": false,
          "arg_schema": {
            "type": "object",
            "properties": {"url": {"type": "string"}},
            "required": ["url"]
          }
